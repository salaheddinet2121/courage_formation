---
import '@/styles/global.css';
import { SITE_TITLE, SITE_METADATA } from '../consts';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  noindex = false,
} = Astro.props;

const finalTitle = title || SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.site);
const isArticle = type === 'article';
---

<!-- Preconnects -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet" />

<!-- Core -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Robots -->
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />
<meta name="keywords" content={SITE_METADATA.keywords.join(', ')} />
<meta name="author" content={author || SITE_METADATA.authors[0].name} />

<!-- GEO — Local SEO France -->
<meta name="geo.region" content="FR" />
<meta name="geo.country" content="France" />
<meta name="language" content="French" />
<meta name="content-language" content="fr" />
<meta name="DC.language" content="fr" />

<!-- Open Graph -->
<meta property="og:locale" content="fr_FR" />
<meta property="og:type" content={isArticle ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content={SITE_METADATA.openGraph.images[0].width.toString()} />
<meta property="og:image:height" content={SITE_METADATA.openGraph.images[0].height.toString()} />
<meta property="og:image:alt" content={finalTitle} />
<meta property="og:image:type" content="image/jpeg" />

<!-- Article-specific OG -->
{isArticle && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{isArticle && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{isArticle && <meta property="article:author" content={author || 'Équipe Courage Formation'} />}
{isArticle && <meta property="article:publisher" content="https://courageformation.fr" />}
{isArticle && <meta property="article:section" content="Formation professionnelle" />}

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@courageformation" />
<meta name="twitter:creator" content="@courageformation" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={finalTitle} />

<!-- Favicons -->
{SITE_METADATA.icons.icon.map((icon) => (
  <link rel="icon" type={icon.type} sizes={icon.sizes} href={icon.url} />
))}
{SITE_METADATA.icons.apple.map((icon) => (
  <link rel="apple-touch-icon" sizes={icon.sizes} href={icon.url} />
))}
<link rel="shortcut icon" href="/favicon/favicon.ico" />

<!-- Sitemap & RSS -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
