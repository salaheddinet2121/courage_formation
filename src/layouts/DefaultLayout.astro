---
import { ClientRouter } from 'astro:transitions';

import BaseHead from '@/components/BaseHead.astro';
import { NavigationProvider } from '@/components/elements/navigation-provider';
import Footer from '@/components/layout/footer';
import Navbar from '@/components/layout/navbar';
import CTA from '@/components/sections/cta';

const { title, description, heroBg } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="fr">
  <head>
    <ClientRouter />
    <BaseHead title={title} description={description} />
    <meta name="view-transition" content="same-origin" />
  </head>
  <body class="antialiased flex flex-col min-h-screen">
    <NavigationProvider client:load currentPath={currentPath}>
      <!-- Navbar + hero: bg image only on homepage -->
      <div class="relative">
        {currentPath === '/' && (
          <>
            <img
              src="/layout/hero-desktop.webp"
              alt=""
              aria-hidden="true"
              class="absolute inset-0 hidden md:block w-full pointer-events-none select-none"
            />
            <img
              src="/layout/hero-mobile.webp"
              alt=""
              aria-hidden="true"
              class="absolute inset-0 block md:hidden w-full pointer-events-none select-none"
            />
          </>
        )}
        <div class="relative z-10">
          <Navbar currentPage={currentPath} client:load />
          <slot name="hero" />
        </div>
      </div>
      <main class="flex-1" style="view-transition-name: main;"><slot /></main>
      <CTA pathname={Astro.url.pathname} client:load />
      <Footer />
    </NavigationProvider>
  </body>
</html>
