---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout
  title="Incubateur de Formateurs — Courage Formation"
  description="Rejoignez l'incubateur Courage Formation : un programme intensif pour lancer, structurer et développer votre activité de formateur en 90 jours."
>
  <div class="section-padding container space-y-16">

    <!-- Hero -->
    <div class="text-center space-y-4 max-w-3xl mx-auto pt-8">
      <span class="inline-block rounded-full bg-secondary px-3 py-1 text-xs text-secondary-foreground font-medium border border-secondary">
        Incubateur
      </span>
      <h1 class="text-3xl font-bold md:text-4xl lg:text-5xl">
        Lancez votre activité de formateur en 90 jours
      </h1>
      <p class="text-muted-foreground text-base max-w-xl mx-auto">
        Un programme structuré, un mentor dédié et une communauté de formateurs pour aller de l'idée au premier client sans perdre de temps.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center rounded-full bg-foreground px-7 py-3 text-sm font-semibold text-background hover:bg-foreground/85 transition-colors"
      >
        Rejoindre l'incubateur
      </a>
    </div>

    <!-- Programme -->
    <div class="max-w-4xl mx-auto space-y-6">
      <h2 class="text-2xl font-bold text-center">Le programme en 3 phases</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="p-6 rounded-2xl space-y-3" style="background-color: #fafafa;">
          <div class="text-accent font-bold text-sm">Phase 1 — Semaines 1 à 4</div>
          <h3 class="font-bold">Structurer</h3>
          <p class="text-sm text-muted-foreground leading-7">
            Définir votre positionnement, votre offre de formation, votre modèle économique et créer votre organisme de formation conforme.
          </p>
        </div>

        <div class="p-6 rounded-2xl space-y-3" style="background-color: #fafafa;">
          <div class="text-accent font-bold text-sm">Phase 2 — Semaines 5 à 8</div>
          <h3 class="font-bold">Certifier</h3>
          <p class="text-sm text-muted-foreground leading-7">
            Préparer et passer votre audit Qualiopi, accéder à l'EDOF et au CPF, et obtenir les financements nécessaires à votre croissance.
          </p>
        </div>

        <div class="p-6 rounded-2xl space-y-3" style="background-color: #fafafa;">
          <div class="text-accent font-bold text-sm">Phase 3 — Semaines 9 à 12</div>
          <h3 class="font-bold">Développer</h3>
          <p class="text-sm text-muted-foreground leading-7">
            Lancer votre stratégie d'acquisition, remplir vos premières sessions et mettre en place des systèmes de croissance durables.
          </p>
        </div>

      </div>
    </div>

    <!-- Ce qui est inclus -->
    <div class="max-w-2xl mx-auto space-y-6">
      <h2 class="text-2xl font-bold text-center">Ce qui est inclus</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm text-muted-foreground">
        {[
          "Création complète de votre OF",
          "Accompagnement Qualiopi",
          "Accès CPF / EDOF",
          "Coaching individuel hebdomadaire",
          "Accès au groupe privé",
          "Templates et ressources exclusives",
          "Stratégie marketing personnalisée",
          "Suivi des KPIs et tableau de bord",
        ].map((item) => (
          <li class="flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-accent shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <!-- CTA -->
    <div class="text-center space-y-4 py-8">
      <h2 class="text-2xl font-bold">Prêt à rejoindre l'incubateur ?</h2>
      <p class="text-muted-foreground text-sm">Les places sont limitées. Réservez votre appel de découverte dès maintenant.</p>
      <a
        href="/contact"
        class="inline-flex items-center rounded-full bg-foreground px-7 py-3 text-sm font-semibold text-background hover:bg-foreground/85 transition-colors"
      >
        Réserver mon appel découverte
      </a>
    </div>

  </div>
</DefaultLayout>
