---
import { getCollection } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import AboutContent from '@/components/sections/about-content';
import BlogPosts from '@/components/sections/blog-posts';

const blogPosts = await getCollection('blog');
---

<DefaultLayout
  title="À Propos — Courage Formation, votre cabinet de formation"
  description="Découvrez l'équipe Courage Formation, notre mission et nos valeurs. Nous accompagnons les formateurs et centres de formation à se lancer, se certifier et croître."
>
  <AboutContent client:load />
  <BlogPosts posts={blogPosts.slice(0, 3)} client:load />
</DefaultLayout>
