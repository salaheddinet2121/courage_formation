---
import PricingPage from '@/components/sections/pricing-page';
import FAQ from '@/components/sections/faq';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const pricingJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://courageformation.fr' },
      { '@type': 'ListItem', position: 2, name: 'Tarifs', item: 'https://courageformation.fr/pricing' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Offres Qualiopi — Courage Formation',
    description: 'Trois offres d\'accompagnement Qualiopi à partir de 990€.',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        item: {
          '@type': 'Service',
          name: 'E-Qualiopi',
          description: 'Formation e-learning complète pour obtenir Qualiopi en autonomie.',
          url: 'https://courageformation.fr/services/qualiopi/e-qualiopi',
          offers: {
            '@type': 'Offer',
            price: '990',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
          },
        },
      },
      {
        '@type': 'ListItem',
        position: 2,
        item: {
          '@type': 'Service',
          name: 'Qualiopi + Audits Blancs',
          description: '3 simulations d\'audit, coaching expert et 4 sessions live Q&R.',
          url: 'https://courageformation.fr/services/qualiopi/audits-blancs',
          offers: {
            '@type': 'Offer',
            price: '1990',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
          },
        },
      },
      {
        '@type': 'ListItem',
        position: 3,
        item: {
          '@type': 'Service',
          name: 'Je Passe Ton Audit — Offre Garantie',
          description: 'Un expert Courage Formation passe votre audit Qualiopi à votre place. Garantie 100% réussite.',
          url: 'https://courageformation.fr/services/qualiopi/offre-garantie',
          offers: {
            '@type': 'Offer',
            price: '2490',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
          },
        },
      },
    ],
  },
];
---

<DefaultLayout
  title="Tarifs Qualiopi 2025 — E-Qualiopi, Audits Blancs, Offre Garantie | Courage Formation"
  description="Obtenez Qualiopi à partir de 990€. E-Qualiopi e-learning, coaching avec audits blancs ou prise en charge complète de l'audit. Garantie sur toutes les offres."
  jsonLd={pricingJsonLd}
>
  <PricingPage client:load />
  <FAQ client:load />
</DefaultLayout>
